APP_NAME=Luma
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://luma.test

APP_LOCALE=es
APP_FAKER_LOCALE=es_VE

LOG_CHANNEL=stack
LOG_LEVEL=debug

# PostgreSQL (DBngin local o Docker en produccion)
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=salones
DB_USERNAME=postgres
DB_PASSWORD=

# Redis
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Cache, Session, Queue, Broadcast (redis para prod, file/sync para dev local)
CACHE_STORE=file
SESSION_DRIVER=file
QUEUE_CONNECTION=sync
BROADCAST_CONNECTION=reverb

FILESYSTEM_DISK=local

# Sanctum (SPA auth)
SANCTUM_STATEFUL_DOMAINS=luma.test,localhost:5173
SESSION_DOMAIN=null
SESSION_LIFETIME=120
SESSION_ENCRYPT=false

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://luma.test

# Octane / FrankenPHP
OCTANE_SERVER=frankenphp
OCTANE_HTTPS=true
OCTANE_WORKERS=auto
OCTANE_MAX_EXECUTION_TIME=60
OCTANE_WATCH=false

# Horizon
HORIZON_PREFIX=""
HORIZON_ENV=production

# Reverb (WebSockets)
REVERB_APP_ID=salones
REVERB_APP_KEY=salones-key
REVERB_APP_SECRET=salones-secret
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http
REVERB_ALLOWED_ORIGINS=http://localhost:5173,https://luma.test

# Mail
MAIL_MAILER=log
MAIL_FROM_ADDRESS="app@luma.test"
MAIL_FROM_NAME="${APP_NAME}"

# Web Push VAPID keys (generated once with: php artisan vapid:generate or manually)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@luma.app

VITE_APP_NAME="${APP_NAME}"
