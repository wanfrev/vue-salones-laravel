{
    {$CADDY_GLOBAL_OPTIONS}
}

{$DOMAIN:localhost} {
    root * /app/public

    encode zstd gzip

    header {
        X-Frame-Options "DENY"
        X-Content-Type-Options "nosniff"
        -Server
    }

    # API -> Laravel
    handle /api/* {
        php_server {
            resolve_root_symlink
        }
    }

    # Health check -> Laravel
    handle /up {
        php_server
    }

    # Reverb WebSocket
    @reverb {
        header Connection *Upgrade*
        header Upgrade    websocket
    }
    reverse_proxy @reverb localhost:8080

    # Static frontend assets (built by Vite)
    handle /build/* {
        file_server {
            precompressed zstd br gzip
        }
    }

    # SPA fallback: all non-API routes serve the Vue SPA
    handle {
        try_files {path} /build/index.html
        file_server
    }

    frankenphp {
        worker /app/public/frankenphp-worker.php
        num_workers {$OCTANE_WORKERS:auto}
        max_execution_time {$OCTANE_MAX_EXECUTION_TIME:60}
    }
}
